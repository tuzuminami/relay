{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://relay.local/schemas/provider-validation-request.schema.json",
  "title": "ProviderValidationRequest",
  "type": "object",
  "additionalProperties": false,
  "required": ["providerId", "adapterType", "baseUrl", "capabilities", "secretReference"],
  "properties": {
    "providerId": {
      "type": "string",
      "minLength": 1
    },
    "adapterType": {
      "const": "openai-compatible"
    },
    "baseUrl": {
      "type": "string",
      "minLength": 1
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": ["chat", "stream", "embeddings", "tools", "json_mode", "vision"]
      }
    },
    "secretReference": {
      "type": "string",
      "pattern": "^secret://"
    }
  }
}
