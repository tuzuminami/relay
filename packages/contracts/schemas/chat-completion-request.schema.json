{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://relay.local/schemas/chat-completion-request.schema.json",
  "title": "ChatCompletionRequest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "model",
    "purpose",
    "dataClassification",
    "messages",
    "requiredCapabilities",
    "maxCostCents"
  ],
  "properties": {
    "model": {
      "type": "string",
      "minLength": 1
    },
    "purpose": {
      "type": "string",
      "minLength": 1
    },
    "dataClassification": {
      "enum": ["public", "internal", "confidential", "restricted"]
    },
    "messages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["role", "content"],
        "properties": {
          "role": {
            "enum": ["system", "user", "assistant", "tool"]
          },
          "content": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "requiredCapabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": ["chat", "stream", "embeddings", "tools", "json_mode", "vision"]
      }
    },
    "maxCostCents": {
      "type": "integer",
      "minimum": 0
    },
    "toolsStarted": {
      "type": "boolean"
    }
  }
}
