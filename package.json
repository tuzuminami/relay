{
  "name": "@tuzuminami/relay",
  "version": "1.0.0",
  "private": false,
  "type": "module",
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.30.2",
  "files": [
    "apps",
    "packages",
    "db",
    "scripts",
    "docs/adr",
    "docs/runbooks",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc --noEmit",
    "check:private-boundary": "node scripts/check-private-boundary.mjs",
    "db:migrate": "node scripts/apply-sql.mjs db/migrations/0001_initial.sql",
    "db:seed": "node scripts/apply-sql.mjs db/seeds/development.sql",
    "start:api": "node --experimental-strip-types apps/api/src/main.ts",
    "test": "node --test --experimental-strip-types tests/*.test.ts",
    "verify": "pnpm run check:private-boundary && pnpm run build && pnpm test && pnpm pack --dry-run"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/pg": "^8.20.0",
    "typescript": "^5.9.0"
  },
  "dependencies": {
    "pg": "^8.22.0",
    "undici": "^7.28.0"
  }
}
